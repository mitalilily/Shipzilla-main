{
  "info": {
    "name": "Shipmozo Courier API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://shipping-api.com/app/api/v1" },
    { "key": "username", "value": "" },
    { "key": "password", "value": "" },
    { "key": "publicKey", "value": "" },
    { "key": "privateKey", "value": "" },
    { "key": "orderId", "value": "SZTEST-{{$timestamp}}" },
    { "key": "awbNumber", "value": "" },
    { "key": "warehouseId", "value": "" },
    { "key": "courierId", "value": "" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Shipmozo response has result/message/data', function () {",
          "  var body = pm.response.json();",
          "  pm.expect(body).to.have.property('result');",
          "  pm.expect(body).to.have.property('message');",
          "  pm.expect(body).to.have.property('data');",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Info",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/info"
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var body = pm.response.json();",
              "if (body.result === '1' && Array.isArray(body.data) && body.data[0]) {",
              "  pm.collectionVariables.set('publicKey', body.data[0].public_key);",
              "  pm.collectionVariables.set('privateKey', body.data[0].private_key);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "username", "value": "{{username}}" },
            { "key": "password", "value": "{{password}}" }
          ]
        },
        "url": "{{baseUrl}}/login"
      }
    },
    {
      "name": "Pincode Serviceability",
      "request": {
        "method": "POST",
        "header": [
          { "key": "public_key", "value": "{{publicKey}}" },
          { "key": "private_key", "value": "{{privateKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"pickup_pincode\":122001,\"delivery_pincode\":110001}"
        },
        "url": "{{baseUrl}}/pincode-serviceability"
      }
    },
    {
      "name": "Rate Calculator",
      "request": {
        "method": "POST",
        "header": [
          { "key": "public_key", "value": "{{publicKey}}" },
          { "key": "private_key", "value": "{{privateKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"order_id\":\"\",\"pickup_pincode\":122001,\"delivery_pincode\":110001,\"payment_type\":\"PREPAID\",\"shipment_type\":\"FORWARD\",\"order_amount\":1000,\"type_of_package\":\"SPS\",\"rov_type\":\"ROV_OWNER\",\"cod_amount\":\"\",\"weight\":500,\"dimensions\":[{\"no_of_box\":\"1\",\"length\":\"22\",\"width\":\"10\",\"height\":\"10\"}]}"
        },
        "url": "{{baseUrl}}/rate-calculator"
      }
    },
    {
      "name": "Get Warehouses",
      "request": {
        "method": "GET",
        "header": [
          { "key": "public_key", "value": "{{publicKey}}" },
          { "key": "private_key", "value": "{{privateKey}}" }
        ],
        "url": "{{baseUrl}}/get-warehouses"
      }
    },
    {
      "name": "Get Return Reasons",
      "request": {
        "method": "GET",
        "header": [
          { "key": "public_key", "value": "{{publicKey}}" },
          { "key": "private_key", "value": "{{privateKey}}" }
        ],
        "url": "{{baseUrl}}/get-return-reason"
      }
    },
    {
      "name": "Track Order",
      "request": {
        "method": "GET",
        "header": [
          { "key": "public_key", "value": "{{publicKey}}" },
          { "key": "private_key", "value": "{{privateKey}}" }
        ],
        "url": "{{baseUrl}}/track-order?awb_number={{awbNumber}}"
      }
    }
  ]
}
